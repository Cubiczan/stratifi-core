# Stratifi Core environment configuration
# Copy to .env and fill in real values. Never commit .env.

# SQLAlchemy connection URL for the persistence layer.
# CockroachDB / PostgreSQL example:
#   STRATIFI_DATABASE_URL=cockroachdb+psycopg2://USER:PASSWORD@HOST:26257/stratifi_core?sslmode=require
# If unset, the app falls back to a local SQLite database (development only).
STRATIFI_DATABASE_URL=

# Optional DB timeouts.
STRATIFI_DB_CONNECT_TIMEOUT=5
STRATIFI_DB_STATEMENT_TIMEOUT_MS=5000
